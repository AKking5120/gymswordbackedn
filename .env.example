# ⚠️  WARNING: Never commit this file to version control!
# Copy to .env and fill in your values.

# Server
PORT=5000
NODE_ENV=development

# Supabase (PostgreSQL)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT Authentication
JWT_SECRET=change_this_to_a_random_64_char_string
JWT_REFRESH_SECRET=change_this_to_another_random_64_char_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Razorpay Payments
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# SMTP Email (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Site URL
SITE_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3000

# Cloudinary (Image Upload)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# AI Chatbot (OpenAI / Gemini)
# To use AI features, set either OPENAI_API_KEY or GEMINI_API_KEY
# If both are empty, the rule-based fallback is used.
AI_API_KEY=sk-your-openai-api-key
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo

# For Gemini, use:
# AI_API_KEY=your-gemini-key
# AI_API_URL=https://generativelanguage.googleapis.com/v1beta/models/gemini-pro:generateContent
# AI_MODEL=gemini-pro

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Redis (optional - for production caching)
# REDIS_URL=redis://localhost:6379
